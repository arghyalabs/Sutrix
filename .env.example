# Scientific Data Orchestrator - Global Configuration
# Do not place actual secrets in this file. Copy to .env and configure locally.

# Deployment Environment
APP_ENV=development

# Backend Settings
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change_this_in_production
JWT_SECRET=change_this_in_production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=uploads
EXPORT_DIR=exports
CACHE_DIR=cache
MAX_UPLOAD_MB=500
WS_HEARTBEAT_INTERVAL=30
ENABLE_GPU=false
ENABLE_BACKGROUND_WORKERS=true

# Frontend Settings
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME="Scientific Data Orchestrator"
VITE_ENABLE_ANALYTICS=false
